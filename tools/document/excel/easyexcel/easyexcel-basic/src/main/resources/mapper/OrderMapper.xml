<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tools.document.excel.easyexcel.basic.web.mapper.OrderMapper">
    <select id="getOrderlist" resultType="com.tools.document.excel.easyexcel.basic.web.entity.OrderBO">
  select
  id ,
  orderId ,
  `address`,
  `createTime`,
  `productId` ,
  `name`,
  `subtitle` ,
  `brandName` ,
  `price` ,
  `count`  from tbl_order
    </select>
</mapper>
